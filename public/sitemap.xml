import type { MetadataRoute } from "next";

/* ═══════════════════════════════════════════════════════════════════
   src/app/sitemap.ts — visa.mytriplooker.com
   ─────────────────────────────────────────────
   Next.js 14 native sitemap generation.
   This auto-generates /sitemap.xml at build time.
   
   AUDIT FIX: sitemap.xml was returning 404.
   
   NOTE: Add any new public pages here as you create them.
   Do NOT add auth/admin/dashboard pages — those should stay hidden.
   ═══════════════════════════════════════════════════════════════════ */

const BASE = "https://visa.mytriplooker.com";

export default function sitemap(): MetadataRoute.Sitemap {
  const now = new Date().toISOString();

  /* ── Core pages ── */
  const corePages: MetadataRoute.Sitemap = [
    {
      url: BASE,
      lastModified: now,
      changeFrequency: "daily",
      priority: 1.0,
    },
    {
      url: `${BASE}/apply`,
      lastModified: now,
      changeFrequency: "weekly",
      priority: 0.9,
    },
    {
      url: `${BASE}/checklist`,
      lastModified: now,
      changeFrequency: "weekly",
      priority: 0.7,
    },
  ];

  /* ── Destination / visa pages ──
     Add every country slug you have under /visa/[country].
     Each of these targets a long-tail keyword like
     "dubai visa for indians" or "thailand visa online".
     This is CRITICAL for top-3 ranking per destination. */
  const destinationSlugs = [
    "dubai",
    "thailand",
    "vietnam",
    "indonesia",
    "malaysia",
    "singapore",
    "japan",
    "south-korea",
    "turkey",
    "egypt",
    "azerbaijan",
    "sri-lanka",
    // Add more country slugs here as you create pages
  ];

  const destinationPages: MetadataRoute.Sitemap = destinationSlugs.map(
    (slug) => ({
      url: `${BASE}/visa/${slug}`,
      lastModified: now,
      changeFrequency: "weekly" as const,
      priority: 0.9,
    })
  );

  return [...corePages, ...destinationPages];
}